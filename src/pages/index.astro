---

<Layout
	title="Jorge Arturo Gonzalez Rodriguez | Desarrollador PHP y Laravel Backend"
	description="Portfolio de Jorge Arturo Gonzalez Rodriguez, desarrollador backend con enfoque en PHP, Laravel, integración de APIs REST y SOAP, y bases de datos MySQL y SQL Server."
>
	<Header />
	<main>
		<Hero />
		<Profile />
		<Stack />
		<Experience />
		<Projects />
		<Contact />
	</main>
	<Footer />
	<DetailModal />
</Layout>
