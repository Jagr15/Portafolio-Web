---
---

<div id="detail-modal" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
  <div id="detail-modal-overlay" class="absolute inset-0 bg-slate-950/90 backdrop-blur-md cursor-zoom-out"></div>
  
  <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10 flex flex-col pointer-events-none h-full overflow-hidden">
    
    <!-- Modal Contenedor Principal -->
    <div class="bg-slate-900 border border-slate-800 shadow-2xl rounded-2xl flex flex-col pointer-events-auto max-h-full overflow-hidden">
      
      <!-- Controles Header -->
      <div class="flex justify-between items-start p-6 border-b border-slate-800 bg-slate-900/50">
        <div class="flex flex-col pr-8">
          <h3 id="dm-title" class="text-2xl sm:text-3xl font-bold text-white"></h3>
          <p id="dm-subtitle" class="text-primary-400 font-medium mt-1 text-sm sm:text-base"></p>
        </div>
        <button id="dm-close" class="p-2.5 rounded-full bg-slate-800/80 text-slate-300 hover:text-white hover:bg-slate-700 hover:border-slate-600 border border-slate-700 transition-all shadow-lg shrink-0" aria-label="Cerrar modal">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <!-- Scroller del contenido -->
      <div class="flex-1 overflow-y-auto custom-scrollbar p-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
          
          <!-- Lado Izquierdo: Textos -->
          <div id="dm-text-col" class="lg:col-span-7 space-y-8">
            
            <!-- Descripcion General / Summary -->
            <div id="dm-summary-container" class="hidden">
              <p id="dm-summary" class="text-slate-300 text-base sm:text-lg leading-relaxed"></p>
            </div>

            <!-- Grid de bloques de texto (Problema/Solucion) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div id="dm-problem-container" class="hidden bg-slate-800/50 p-5 rounded-xl border border-slate-700/50">
                <div class="flex items-center mb-3">
                  <svg class="w-5 h-5 text-red-400 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  <h4 class="text-lg font-semibold text-white">El Problema</h4>
                </div>
                <p id="dm-problem" class="text-slate-400 text-sm leading-relaxed"></p>
              </div>

              <div id="dm-solution-container" class="hidden bg-primary-900/20 p-5 rounded-xl border border-primary-800/30">
                <div class="flex items-center mb-3">
                  <svg class="w-5 h-5 text-primary-400 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <h4 class="text-lg font-semibold text-white">Solución implementada</h4>
                </div>
                <p id="dm-solution" class="text-slate-400 text-sm leading-relaxed"></p>
              </div>
            </div>

            <!-- Contribucion o Responsabilidades -->
            <div id="dm-contribution-container" class="hidden">
              <h4 id="dm-contribution-title" class="text-xl font-bold text-white mb-4 flex items-center">
                <svg class="w-5 h-5 text-slate-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                Mi Participación
              </h4>
              <div id="dm-contribution-content" class="text-slate-300 text-sm leading-relaxed space-y-2"></div>
            </div>

            <!-- Logros / Impacto -->
            <div id="dm-impact-container" class="hidden relative pl-4 border-l-4 border-primary-500">
              <h4 id="dm-impact-title" class="text-lg font-bold text-white mb-2">Impacto y Resultados</h4>
              <div id="dm-impact-content" class="text-slate-300 text-sm leading-relaxed space-y-2"></div>
            </div>

            <!-- Stack -->
            <div id="dm-stack-container" class="hidden">
              <h4 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">Tecnologías Utilizadas</h4>
              <div id="dm-stack" class="flex flex-wrap gap-2"></div>
            </div>

          </div>

          <!-- Lado Derecho: Carrusel de Imagenes -->
          <div id="dm-media-col" class="lg:col-span-5 flex flex-col self-start space-y-4">
            
            <div class="relative w-full aspect-[16/10] bg-slate-950 rounded-xl border border-slate-800 shadow-inner overflow-hidden flex items-center justify-center group/media">
              
              <button id="dm-prev" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-slate-900/80 hover:bg-primary-600 border border-slate-700 hover:border-primary-500 text-white transition-all shadow-lg backdrop-blur z-20 group">
                <svg class="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </button>
              
              <button id="dm-next" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-slate-900/80 hover:bg-primary-600 border border-slate-700 hover:border-primary-500 text-white transition-all shadow-lg backdrop-blur z-20 group">
                <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>

              <button id="dm-expand-trigger" class="absolute top-3 right-3 px-3 py-1.5 rounded-lg bg-slate-900/85 border border-slate-700/80 text-slate-200 hover:text-white hover:border-primary-500/70 hover:bg-slate-800/90 transition-all shadow-md z-20 flex items-center gap-2 text-xs font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 1v4m0 0h-4m4 0l-5-5"></path></svg>
                Ver captura completa
              </button>

              <img id="dm-image" src="" alt="Screenshot" class="w-full h-full object-contain transition-opacity duration-300" />
              
              <div id="dm-loader" class="absolute inset-0 flex items-center justify-center bg-slate-950/80 z-10 transition-opacity duration-300">
                <svg class="animate-spin h-8 w-8 text-primary-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              </div>

              <!-- Contador embebido en esquina de imagen -->
              <div class="absolute bottom-3 right-3 bg-slate-900/80 backdrop-blur text-slate-300 text-xs font-semibold px-2.5 py-1 rounded-md border border-slate-700/50 z-20 shadow-md">
                 <span id="dm-counter">1 / 1</span>
              </div>
            </div>
            
            <!-- Thumbnail Track -->
            <div id="dm-thumbnails-wrapper" class="w-full bg-slate-900/30 rounded-xl border border-slate-800/80 pointer-events-auto">
              <div id="dm-thumbnails" class="flex items-center gap-2 overflow-x-auto p-3 custom-scrollbar snap-x">
                 <!-- Inyectados por JS -->
              </div>
            </div>
            
          </div>
          
        </div>
      </div>
    </div>
  </div>
</div>

<div id="dm-image-lightbox" class="fixed inset-0 z-[120] hidden items-center justify-center p-4 sm:p-8">
  <div id="dm-image-lightbox-overlay" class="absolute inset-0 bg-slate-950/95 backdrop-blur-sm"></div>
  <div class="relative z-10 w-full h-full flex items-center justify-center">
    <button id="dm-image-lightbox-close" class="absolute top-2 right-2 sm:top-4 sm:right-4 p-3 rounded-full bg-slate-800/90 text-slate-200 hover:text-white border border-slate-700 hover:border-primary-500 transition-all shadow-lg" aria-label="Cerrar vista ampliada">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div class="absolute top-3 left-3 sm:top-5 sm:left-5 px-3 py-1.5 rounded-md bg-slate-900/85 border border-slate-700/80 text-slate-300 text-xs font-semibold">
      <span id="dm-image-lightbox-counter">Captura 1 de 1</span>
    </div>
    <img id="dm-image-lightbox-src" src="" alt="Captura ampliada" class="max-w-full max-h-full object-contain rounded-xl border border-slate-700/80 shadow-2xl" />
    <div id="dm-image-lightbox-fallback" class="hidden max-w-md w-full rounded-xl border border-slate-700/80 bg-slate-900/85 p-6 sm:p-8 text-center shadow-2xl">
      <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center">
        <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h18M3 19h18M5 5v14m14-14v14M9 10l2 2 4-4"></path></svg>
      </div>
      <p id="dm-image-lightbox-fallback-text" class="text-slate-300 text-sm sm:text-base leading-relaxed">
        No fue posible mostrar la captura ampliada en este momento.
      </p>
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: rgba(30, 41, 59, 0.5); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(59, 130, 246, 0.3); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(59, 130, 246, 0.6); }
  
  /* Formato HTML para listas en js injection */
  .list-injected ul { list-style-type: disc; margin-left: 1.25rem; space-y: 0.5rem; }
  .list-injected li { margin-bottom: 0.5rem; }
</style>

<script>
  let modalActiveScreenshots: string[] = [];
  let modalCurrentIndex = 0;
  
  const dModal = document.getElementById('detail-modal');
  const dOverlay = document.getElementById('detail-modal-overlay');
  const dCloseBtn = document.getElementById('dm-close');
  
  const imgEl = document.getElementById('dm-image') as HTMLImageElement;
  const loaderEl = document.getElementById('dm-loader');
  const counterEl = document.getElementById('dm-counter');
  const prevBtn = document.getElementById('dm-prev');
  const nextBtn = document.getElementById('dm-next');
  const expandBtn = document.getElementById('dm-expand-trigger');
  const thumbnailsContainer = document.getElementById('dm-thumbnails');
  const dMediaCol = document.getElementById('dm-media-col');
  const dTextCol = document.getElementById('dm-text-col');
  const lightbox = document.getElementById('dm-image-lightbox');
  const lightboxOverlay = document.getElementById('dm-image-lightbox-overlay');
  const lightboxCloseBtn = document.getElementById('dm-image-lightbox-close');
  const lightboxImg = document.getElementById('dm-image-lightbox-src') as HTMLImageElement;
  const lightboxCounter = document.getElementById('dm-image-lightbox-counter');
  const lightboxFallback = document.getElementById('dm-image-lightbox-fallback');
  const lightboxFallbackText = document.getElementById('dm-image-lightbox-fallback-text');
  
  function getSafeValue(val: any) {
    if (!val) return null;
    if (Array.isArray(val) && val.length === 0) return null;
    return val;
  }

  function setHtmlOrHide(containerId: string, contentId: string, htmlContent: string | null) {
      const container = document.getElementById(containerId);
      const content = document.getElementById(contentId);
      if(htmlContent && container && content) {
          container.classList.remove('hidden');
          content.innerHTML = htmlContent;
      } else if (container) {
          container.classList.add('hidden');
      }
  }

  function setTextOrHide(containerId: string, contentId: string, textContent: string | null) {
      const container = document.getElementById(containerId);
      const content = document.getElementById(contentId);
      if(textContent && container && content) {
          container.classList.remove('hidden');
          content.textContent = textContent;
      } else if (container) {
          container.classList.add('hidden');
      }
  }

  function renderList(items: string[]) {
      if(!items || items.length === 0) return null;
      return `<ul class="list-injected pl-2 marker:text-slate-600">${items.map(i => `<li>${i}</li>`).join('')}</ul>`;
  }

  function dmShowLightboxFallback(message: string) {
    if (lightboxFallbackText) lightboxFallbackText.textContent = message;
    if (lightboxFallback) lightboxFallback.classList.remove('hidden');
    if (lightboxImg) {
      lightboxImg.classList.add('hidden');
      lightboxImg.removeAttribute('src');
    }
  }

  function dmHideLightboxFallback() {
    if (lightboxFallback) lightboxFallback.classList.add('hidden');
    if (lightboxImg) lightboxImg.classList.remove('hidden');
  }

  function dmSyncExpandedImage() {
    if (!lightboxImg) return;
    if (modalActiveScreenshots.length === 0) {
      if (lightboxCounter) lightboxCounter.textContent = 'Captura 0 de 0';
      dmShowLightboxFallback('Esta evidencia no tiene captura disponible para ampliar.');
      return;
    }

    const currentSrc = modalActiveScreenshots[modalCurrentIndex];
    if (!currentSrc) {
      if (lightboxCounter) lightboxCounter.textContent = 'Captura no disponible';
      dmShowLightboxFallback('No se encontró la captura activa para mostrar en grande.');
      return;
    }

    if (lightboxCounter) {
      lightboxCounter.textContent = `Captura ${modalCurrentIndex + 1} de ${modalActiveScreenshots.length}`;
    }

    const expectedSrc = currentSrc;
    const preload = new Image();
    preload.onload = () => {
      if (modalActiveScreenshots[modalCurrentIndex] !== expectedSrc) return;
      lightboxImg.src = expectedSrc;
      dmHideLightboxFallback();
    };
    preload.onerror = () => {
      if (modalActiveScreenshots[modalCurrentIndex] !== expectedSrc) return;
      dmShowLightboxFallback('No fue posible cargar esta captura. Intenta con otra imagen del carrusel.');
    };
    preload.src = expectedSrc;
  }

  function dmOpenExpandedImage() {
    if (!lightbox || !lightboxImg) return;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    dmSyncExpandedImage();
  }

  function dmCloseExpandedImage() {
    if (!lightbox) return;
    lightbox.classList.remove('flex');
    lightbox.classList.add('hidden');
  }

  function openDetailModal(type: 'project' | 'experience', payloadString: string) {
    if (!payloadString) return;
    const data = JSON.parse(payloadString);
    if (!data) return;
    dmCloseExpandedImage();

    // Reset layout
    if(dMediaCol) dMediaCol.classList.remove('hidden');
    if(dTextCol) { dTextCol.classList.remove('lg:col-span-12'); dTextCol.classList.add('lg:col-span-7'); }

    // --- POPULATE HEADERS ---
    const titleEl = document.getElementById('dm-title');
    const subtitleEl = document.getElementById('dm-subtitle');
    
    if (type === 'project') {
       if(titleEl) titleEl.textContent = data.title || '';
       if(subtitleEl) subtitleEl.textContent = data.type || '';
    } else {
       if(titleEl) titleEl.textContent = data.role || '';
       if(subtitleEl) subtitleEl.textContent = `${data.company} • ${data.period}`;
    }

    // --- POPULATE TEXTS ---
    // Summary
    const summaryText = type === 'project' ? data.description : data.summary;
    setTextOrHide('dm-summary-container', 'dm-summary', summaryText);

    // Problem & Solution
    setTextOrHide('dm-problem-container', 'dm-problem', getSafeValue(data.problem));
    setTextOrHide('dm-solution-container', 'dm-solution', getSafeValue(data.solution));

    // Contribution/Responsibilities
    let contribTitleHtml = '';
    let contribContentHtml = '';
    if (type === 'project' && data.contribution) {
       contribTitleHtml = `<svg class="w-5 h-5 text-slate-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg> Mi Participación`;
       contribContentHtml = `<p>${data.contribution}</p>`;
    } else if (type === 'experience' && data.responsibilities && data.responsibilities.length > 0) {
       contribTitleHtml = `<svg class="w-5 h-5 text-slate-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg> Responsabilidades Clave`;
       contribContentHtml = renderList(data.responsibilities) || '';
    }
    const cTitleEl = document.getElementById('dm-contribution-title');
    if(cTitleEl) cTitleEl.innerHTML = contribTitleHtml;
    setHtmlOrHide('dm-contribution-container', 'dm-contribution-content', contribContentHtml || null);


    // Impact / Achievements
    let impactTitleText = type === 'project' ? 'Impacto y Resultados' : 'Logros Destacados';
    let impactContentHtml = '';
    if (type === 'project' && data.impact) {
      impactContentHtml = `<p>${data.impact}</p>`;
    } else if (type === 'experience' && data.achievements && Array.isArray(data.achievements)) {
      impactContentHtml = renderList(data.achievements) || '';
    }
    const iTitleEl = document.getElementById('dm-impact-title');
    if(iTitleEl) iTitleEl.textContent = impactTitleText;
    setHtmlOrHide('dm-impact-container', 'dm-impact-content', impactContentHtml || null);


    // Stack
    const stackItems = type === 'project' ? data.techStack : data.technologies;
    const stackContainer = document.getElementById('dm-stack-container');
    const stackWrap = document.getElementById('dm-stack');
    if (stackItems && stackItems.length > 0 && stackContainer && stackWrap) {
        stackContainer.classList.remove('hidden');
        stackWrap.innerHTML = stackItems.map((tech: string) => 
            `<span class="text-xs font-semibold text-slate-300 bg-slate-800 border border-slate-700 py-1 px-2.5 rounded-md">${tech}</span>`
        ).join('');
    } else if (stackContainer) {
        stackContainer.classList.add('hidden');
    }

    // --- CAROUSEL ---
    if (type === 'project' && data.screenshots && data.screenshots.length > 0) {
       modalActiveScreenshots = data.screenshots;
       modalCurrentIndex = 0;
       if (expandBtn) expandBtn.classList.remove('hidden');
       renderThumbnails();
       dmUpdateImage();
    } else {
       // Ocultar bloque media si no hay screenshots
       modalActiveScreenshots = [];
       modalCurrentIndex = 0;
       if (expandBtn) expandBtn.classList.add('hidden');
       if (thumbnailsContainer) thumbnailsContainer.innerHTML = '';
       if (counterEl) counterEl.textContent = '1 / 1';
       if (imgEl) imgEl.src = '';
       if(dMediaCol) dMediaCol.classList.add('hidden');
       if(dTextCol) { dTextCol.classList.remove('lg:col-span-7'); dTextCol.classList.add('lg:col-span-12'); }
    }

    // Show Modal
    if (dModal) {
      dModal.classList.remove('hidden');
      void dModal.offsetWidth; // force refflow
      dModal.classList.remove('opacity-0');
      dModal.classList.add('opacity-100');
      document.body.style.overflow = 'hidden';
    }
  }

  function dmCloseModal() {
    dmCloseExpandedImage();
    if (dModal) {
      dModal.classList.remove('opacity-100');
      dModal.classList.add('opacity-0');
      setTimeout(() => {
        dModal.classList.add('hidden');
        document.body.style.overflow = '';
        if (imgEl) imgEl.src = ''; 
      }, 300);
    }
  }

  // Carousel Logic (Same as before)
  function dmNextSlide() { if(modalCurrentIndex < modalActiveScreenshots.length - 1) { modalCurrentIndex++; dmUpdateImage(); } }
  function dmPrevSlide() { if(modalCurrentIndex > 0) { modalCurrentIndex--; dmUpdateImage(); } }
  
  function dmUpdateImage() {
    if (!imgEl || !loaderEl || !counterEl) return;
    loaderEl.style.display = 'flex';
    imgEl.style.opacity = '0';
    const newSrc = modalActiveScreenshots[modalCurrentIndex];
    const img = new Image();
    img.onload = () => { imgEl.src = newSrc; loaderEl.style.display = 'none'; imgEl.style.opacity = '1'; };
    img.onerror = () => { imgEl.src = ""; loaderEl.style.display = 'none'; imgEl.style.opacity = '0.5'; };
    img.src = newSrc;
    counterEl.textContent = `${modalCurrentIndex + 1} / ${modalActiveScreenshots.length}`;
    dmUpdateButtonsState();
    dmUpdateThumbnailsState();
    dmSyncExpandedImage();
  }

  function dmUpdateButtonsState() {
    if(!prevBtn || !nextBtn) return;
    prevBtn.classList.toggle('opacity-50', modalCurrentIndex === 0);
    prevBtn.classList.toggle('cursor-not-allowed', modalCurrentIndex === 0);
    prevBtn.classList.toggle('pointer-events-none', modalCurrentIndex === 0);
    nextBtn.classList.toggle('opacity-50', modalCurrentIndex === modalActiveScreenshots.length - 1);
    nextBtn.classList.toggle('cursor-not-allowed', modalCurrentIndex === modalActiveScreenshots.length - 1);
    nextBtn.classList.toggle('pointer-events-none', modalCurrentIndex === modalActiveScreenshots.length - 1);
  }

  function renderThumbnails() {
    if (!thumbnailsContainer) return;
    thumbnailsContainer.innerHTML = '';
    modalActiveScreenshots.forEach((src, idx) => {
      const btn = document.createElement('button');
      btn.className = `w-16 h-12 flex-shrink-0 rounded-md overflow-hidden border-2 transition-all duration-300 snap-center focus:outline-none dm-thumb-btn z-10`;
      btn.classList.add('border-slate-800', 'opacity-50', 'hover:opacity-100');
      const i = document.createElement('img');
      i.src = src; i.className = 'w-full h-full object-cover'; i.loading = 'lazy';
      btn.appendChild(i);
      btn.addEventListener('click', () => { modalCurrentIndex = idx; dmUpdateImage(); });
      thumbnailsContainer.appendChild(btn);
    });
  }

  function dmUpdateThumbnailsState() {
    if (!thumbnailsContainer) return;
    const btns = thumbnailsContainer.querySelectorAll('.dm-thumb-btn');
    btns.forEach((btn, index) => {
      if (index === modalCurrentIndex) {
        btn.classList.remove('border-slate-800', 'opacity-50');
        btn.classList.add('border-primary-500', 'opacity-100');
        if (thumbnailsContainer.scrollWidth > thumbnailsContainer.clientWidth) {
           (btn as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      } else {
        btn.classList.add('border-slate-800', 'opacity-50');
        btn.classList.remove('border-primary-500', 'opacity-100');
      }
    });
  }

  // Swipe support for media carousel
  const mediaContainer = document.getElementById('dm-media-col');
  if(mediaContainer) {
    let tStartX = 0;
    mediaContainer.addEventListener('touchstart', e => { tStartX = (e as TouchEvent).changedTouches[0].screenX; }, {passive:true});
    mediaContainer.addEventListener('touchend', e => {
       const endX = (e as TouchEvent).changedTouches[0].screenX;
       if (endX < tStartX - 50) dmNextSlide();
       if (endX > tStartX + 50) dmPrevSlide();
    }, {passive:true});
  }

  // Listeners
  if(dCloseBtn) dCloseBtn.addEventListener('click', dmCloseModal);
  if(dOverlay) dOverlay.addEventListener('click', dmCloseModal);
  if(prevBtn) prevBtn.addEventListener('click', dmPrevSlide);
  if(nextBtn) nextBtn.addEventListener('click', dmNextSlide);
  if(expandBtn) expandBtn.addEventListener('click', dmOpenExpandedImage);
  if(lightboxOverlay) lightboxOverlay.addEventListener('click', dmCloseExpandedImage);
  if(lightboxCloseBtn) lightboxCloseBtn.addEventListener('click', dmCloseExpandedImage);
  document.addEventListener('keydown', (e) => {
    if(lightbox && !lightbox.classList.contains('hidden')) {
      if(e.key === 'Escape') dmCloseExpandedImage();
      if(e.key === 'ArrowRight') dmNextSlide();
      if(e.key === 'ArrowLeft') dmPrevSlide();
      return;
    }

    if(!dModal || dModal.classList.contains('hidden')) return;
    if(e.key === 'Escape') dmCloseModal();
    if(e.key === 'ArrowRight') dmNextSlide();
    if(e.key === 'ArrowLeft') dmPrevSlide();
  });

  (window as any).openDetailModal = openDetailModal;
</script>
