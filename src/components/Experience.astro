---
import { profileData } from '../data/profile.data';
---

<section id="experiencia" class="py-24 relative z-10">
  <div class="section-container">
    <div class="mb-16 md:mb-20 fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Experiencia Profesional</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-violet-500 to-teal-500 rounded-full"></div>
    </div>
    
    <div class="max-w-3xl mx-auto space-y-6 relative before:absolute before:inset-0 before:ml-5 md:before:ml-[2.5rem] before:-translate-x-px before:h-full before:w-px before:bg-gradient-to-b before:from-violet-500/50 before:via-teal-500/30 before:to-transparent">
      {profileData.experience.map((exp, index) => (
        <div class={`relative flex items-start group fade-up delay-${index * 100}`}>
          <div class="flex items-center justify-center w-10 h-10 md:w-20 md:h-20 rounded-full bg-[#101011] border border-white/10 shrink-0 z-10 md:mr-8 group-hover:border-violet-500/50 transition-colors mt-1 md:mt-0 shadow-lg">
             <div class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-zinc-600 group-hover:bg-violet-400 group-hover:shadow-[0_0_10px_rgba(139,92,246,0.8)] transition-all"></div>
          </div>
          
          <div class="glass-card gradient-border p-6 md:p-8 w-full ml-4 md:ml-0 transition-all hover:bg-[#18181b]/80 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.5)]">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
              <div>
                <h3 class="font-bold text-xl text-white tracking-tight group-hover:text-violet-100 transition-colors">{exp.role}</h3>
                <div class="text-zinc-400 font-medium text-sm md:text-base mt-1">{exp.company}</div>
              </div>
              <span class="inline-flex items-center text-xs font-semibold px-2.5 py-1 bg-white/[0.03] border border-white/10 text-zinc-300 rounded-md whitespace-nowrap self-start md:self-auto group-hover:border-violet-500/30 transition-colors">
                {exp.period}
              </span>
            </div>
            <p class="text-zinc-400 leading-relaxed text-sm md:text-base">
              {exp.summary}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
