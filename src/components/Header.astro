---
import { profileData } from '../data/profile.data';
---

<header class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Name -->
      <div class="flex-shrink-0">
        <a href="#" class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary-400 to-primary-200">
          JAGR<span class="text-primary-500">.</span>
        </a>
      </div>
      
      <!-- Desktop Nav -->
      <nav class="hidden md:block">
        <ul class="flex space-x-8 text-sm font-medium">
          <li><a href="#perfil" class="text-slate-300 hover:text-white transition-colors">Perfil</a></li>
          <li><a href="#stack" class="text-slate-300 hover:text-white transition-colors">Stack</a></li>
          <li><a href="#experiencia" class="text-slate-300 hover:text-white transition-colors">Experiencia</a></li>
          <li><a href="#proyectos" class="text-slate-300 hover:text-white transition-colors">Proyectos</a></li>
          <li><a href="#contacto" class="text-slate-300 hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </nav>

      <!-- Action Button & Links -->
      <div class="hidden md:flex items-center space-x-4">
        <a href={profileData.cta.linkedin} target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors" aria-label="Ver perfil de LinkedIn de Jorge González">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://drive.google.com/drive/folders/17KCiy0XlaviC4ZMQeDRe4PCRJ0qsFnns?usp=sharing" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors text-sm font-medium mr-2">
          Ver cursos y certificaciones
        </a>
        <div class="relative group">
          <button class="px-4 py-2 rounded-lg bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium transition-all shadow-[0_0_15px_rgba(37,99,235,0.3)] hover:shadow-[0_0_20px_rgba(37,99,235,0.5)] flex items-center">
            Descargar CV <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute right-0 mt-2 w-32 bg-slate-800 rounded-md shadow-lg py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <a href="/cv/CV_Jorge_Gonzalez_Backend.pdf" download="CV_Jorge_Gonzalez_Backend.pdf" class="block px-4 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white">Español</a>
            <a href="/cv/CV_Jorge_Gonzalez_Backend_EN.pdf" download="CV_Jorge_Gonzalez_Backend_EN.pdf" class="block px-4 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white">English</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
