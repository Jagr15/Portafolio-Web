---
import { profileData } from '../data/profile.data';
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden flex flex-col justify-center min-h-[85vh]">
  <!-- Glow effects (Violet & Teal) -->
  <div class="absolute top-[40%] left-[35%] -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-violet-600/10 rounded-[100%] blur-[120px] pointer-events-none z-[-1]"></div>
  <div class="absolute top-[60%] left-[65%] -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-teal-500/10 rounded-[100%] blur-[100px] pointer-events-none z-[-1]"></div>
  
  <div class="section-container text-center fade-up">
    <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-amber-500/20 bg-amber-500/5 text-amber-200/90 text-sm font-medium mb-8 backdrop-blur-md hover:bg-amber-500/10 transition-colors">
      <span class="relative flex w-2 h-2 mr-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full w-2 h-2 bg-amber-500"></span>
      </span>
      {profileData.hero.availability}
    </div>
    
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white mb-6 leading-tight">
      {profileData.hero.headline.split('&')[0]} <span class="text-zinc-600 font-light">&</span> <br class="hidden sm:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-300 via-zinc-200 to-teal-200">{profileData.hero.headline.split('&')[1].trim()}</span>
    </h1>
    
    <p class="mt-6 text-lg lg:text-xl text-zinc-400 max-w-3xl mx-auto mb-12 leading-relaxed text-balance">
      {profileData.hero.subheadline}
    </p>
    
    <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-4 mb-20 fade-up delay-100">
      <a href="#proyectos" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-gradient-to-r from-violet-600 to-violet-500 text-white font-semibold transition-all hover:from-violet-500 hover:to-violet-400 hover:scale-[1.02] active:scale-95 shadow-[0_0_20px_rgba(139,92,246,0.3)] hover:shadow-[0_0_30px_rgba(139,92,246,0.5)]">
        Explorar Casos de Estudio
      </a>
      <a href="#contacto" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-zinc-900/80 text-zinc-300 font-medium border border-zinc-700/50 hover:bg-zinc-800 transition-all hover:border-zinc-500 hover:text-white hover:scale-[1.02] active:scale-95 backdrop-blur-sm">
        Contactar Directamente
      </a>
      <a href={profileData.cta.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Ver perfil de LinkedIn de Jorge González" class="w-full sm:w-auto px-6 py-3.5 rounded-xl bg-[#0A66C2]/10 text-[#0A66C2] font-medium border border-[#0A66C2]/20 hover:bg-[#0A66C2]/20 transition-all hover:border-[#0A66C2]/50 hover:scale-[1.02] active:scale-95 flex items-center justify-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Ver perfil profesional
      </a>
      <a href="https://wa.me/527299220102?text=Hola%20Jorge%2C%20vi%20tu%20portafolio%20y%20me%20interesan%20tus%20servicios%20o%20tengo%20una%20propuesta%20de%20trabajo." target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp" class="w-full sm:w-auto px-4 py-3.5 rounded-xl bg-transparent text-emerald-500 font-medium border border-transparent hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" clip-rule="evenodd" fill-rule="evenodd"></path></svg>
        WhatsApp
      </a>
    </div>

    <!-- Metrics Bento Grid Style -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto fade-up delay-200">
      {profileData.hero.metrics.map((metric, idx) => {
        // Vary colors for metrics
        const colors = ['text-violet-400', 'text-teal-400', 'text-amber-400', 'text-zinc-300'];
        const color = colors[idx % colors.length];
        return (
        <div class="glass-card gradient-border p-5 flex flex-col items-center justify-center text-center transition-transform hover:-translate-y-1 duration-300 group">
          <span class={`text-xl sm:text-2xl font-bold mb-1 tracking-tight ${color} group-hover:scale-105 transition-transform`}>{metric.label}</span>
          <span class="text-[11px] sm:text-xs font-semibold text-zinc-500 uppercase tracking-widest">{metric.description}</span>
        </div>
      )})}
    </div>
  </div>
</section>
