---
import { profileData } from '../data/profile.data';
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-24 overflow-hidden">
  <!-- Glowing effects behind -->
  <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[600px] h-[600px] bg-primary-600/20 rounded-full blur-[120px] opacity-40 z-[-1] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[500px] h-[500px] bg-blue-500/10 rounded-full blur-[100px] opacity-30 z-[-1] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-primary-500/30 bg-primary-500/10 text-primary-300 text-sm font-medium mb-10 shadow-[0_0_15px_rgba(59,130,246,0.15)] backdrop-blur-sm">
      <span class="flex w-2.5 h-2.5 rounded-full bg-primary-400 mr-2 animate-pulse shadow-[0_0_8px_rgba(96,165,250,0.8)]"></span>
      Disponible para nuevas oportunidades
    </div>
    
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6">
      <span class="block">Backend empresarial con PHP y Laravel para</span>
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-primary-400 via-blue-200 to-primary-300 py-2">integrar sistemas y evolucionar operaciones</span>
    </h1>
    
    <p class="mt-6 text-lg lg:text-xl text-slate-400 max-w-3xl mx-auto mb-10 leading-relaxed text-balance">
      Hola, soy <strong class="text-white">{profileData.name}</strong>.<br/>
      {profileData.role}.
    </p>
    <p class="text-base lg:text-lg text-slate-500 max-w-3xl mx-auto -mt-4 mb-10 leading-relaxed text-balance">
      Desarrollo servicios backend, integraciones REST y SOAP, y flujos de datos en MySQL y SQL Server para soluciones de negocio mantenibles.
    </p>
    
    <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-4 mb-20">
        <a href="#contacto" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-primary-600 hover:bg-primary-500 text-white font-semibold transition-all shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:shadow-[0_0_30px_rgba(37,99,235,0.6)] ring-1 ring-primary-500/50">
        Contactar ahora
      </a>
      <a href="https://wa.me/527299220102?text=Hola%20Jorge,%20vi%20tu%20portafolio%20y%20me%20interesa%20contactarte." target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-semibold transition-all shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_30px_rgba(16,185,129,0.5)] flex items-center justify-center ring-1 ring-emerald-500/50">
        <svg class="w-5 h-5 mr-1.5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" clip-rule="evenodd" fill-rule="evenodd"></path></svg>
        WhatsApp
      </a>
      <a href="#proyectos" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-slate-800 hover:bg-slate-700 text-white font-medium border border-slate-700 hover:border-slate-500 transition-all shadow-lg hover:shadow-xl">
        Ver Proyectos
      </a>
    </div>

    <!-- Metrics Section for Social Proof -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto border-t border-slate-800/60 pt-10">
        <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-1"><span class="text-primary-400">+</span>3</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-wide">Años en backend</span>
        </div>
        <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-1">REST y SOAP</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-wide">Integración de APIs</span>
        </div>
        <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-1">MySQL y SQL Server</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-wide">Bases de datos</span>
        </div>
        <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-1">Soporte continuo</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-wide">Mantenimiento de sistemas</span>
        </div>
    </div>
  </div>
</section>
