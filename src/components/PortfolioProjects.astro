---
import { profileData } from '../data/profile.data';

// Helper to determine status color
const getStatusColor = (status: string) => {
  const s = status.toLowerCase();
  if (s.includes('producción') || s.includes('operación')) return 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20';
  if (s.includes('desarrollo')) return 'text-amber-400 bg-amber-400/10 border-amber-400/20';
  if (s.includes('mvp')) return 'text-violet-400 bg-violet-400/10 border-violet-400/20';
  return 'text-teal-400 bg-teal-400/10 border-teal-400/20';
};
---

<section id="portfolio" class="py-24 relative z-10 border-t border-white/[0.02] bg-gradient-to-b from-transparent to-[#101011]">
  <div class="section-container">
    <div class="mb-16 md:mb-20 fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Portfolio de Evidencias</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-amber-500 to-transparent rounded-full"></div>
      <p class="mt-5 text-zinc-400 text-lg max-w-2xl leading-relaxed">
        Evidencia visual de proyectos backend, integraciones y demos desarrollados con buenas prácticas de ingeniería.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 auto-rows-fr">
      {profileData.portfolioProjects.map((project, idx) => {
        const isFeatured = project.featured;
        const statusStyle = getStatusColor(project.status);
        
        return (
          <div class={`glass-card ${isFeatured ? 'gradient-border-amber' : 'gradient-border-teal'} flex flex-col group transition-all duration-300 hover:bg-[#18181b]/90 hover:-translate-y-2 hover:shadow-[0_12px_40px_rgba(0,0,0,0.5)] fade-up delay-${(idx % 2) * 100} overflow-hidden`}>
            
            <div class="w-full h-56 sm:h-64 relative overflow-hidden bg-[#0a0a0a]">
               <div class="absolute inset-0 bg-gradient-to-t from-[#18181b] to-transparent opacity-80 z-10"></div>
               {project.image ? (
                 <img src={project.image} alt={`Captura de ${project.title}`} class="w-full h-full object-cover object-top opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
               ) : (
                 <div class="w-full h-full flex flex-col items-center justify-center bg-zinc-900/50 opacity-60">
                   <svg class="w-8 h-8 text-zinc-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                 </div>
               )}
               <div class="absolute top-4 left-4 z-20">
                  <span class="inline-flex items-center px-3 py-1 bg-black/60 backdrop-blur-md border border-white/10 text-xs font-semibold text-zinc-200 rounded-full group-hover:border-white/20 transition-colors">
                    {project.category}
                  </span>
               </div>
               <div class="absolute top-4 right-4 z-20">
                  <span class={`inline-flex items-center px-2.5 py-1 border text-[10px] font-bold uppercase tracking-widest rounded-md backdrop-blur-md ${statusStyle}`}>
                    {project.status}
                  </span>
               </div>
            </div>

            <div class="p-6 md:p-8 flex-1 flex flex-col relative z-20 -mt-6">
              
              <div class="flex justify-between items-start mb-3">
                <h3 class="text-2xl font-bold text-white tracking-tight group-hover:text-amber-200 transition-colors drop-shadow-md">{project.title}</h3>
                
                <div class="flex space-x-2 text-zinc-500 ml-4 shrink-0">
                  {project.githubUrl && (
                    <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white hover:scale-110 transition-all focus:outline-none focus:ring-2 focus:ring-amber-500 rounded-sm" aria-label={`Ver código de ${project.title} en GitHub`}>
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                    </a>
                  )}
                  {project.liveUrl && (
                    <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white hover:scale-110 transition-all focus:outline-none focus:ring-2 focus:ring-amber-500 rounded-sm" aria-label={`Ver demo de ${project.title} en vivo`}>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                    </a>
                  )}
                </div>
              </div>
              
              <p class="text-zinc-400 text-sm leading-relaxed mb-6 flex-1">{project.description}</p>
              
              {project.impact && (
                <div class={`p-4 rounded-xl bg-white/[0.02] border border-white/5 mb-6 transition-colors ${isFeatured ? 'group-hover:bg-amber-500/5 group-hover:border-amber-500/20' : 'group-hover:bg-teal-500/5 group-hover:border-teal-500/20'}`}>
                  <span class={`text-[11px] font-semibold uppercase tracking-widest block mb-1 flex items-center ${isFeatured ? 'text-amber-400' : 'text-teal-400'}`}>
                    <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    Impacto
                  </span>
                  <p class="text-zinc-300 text-sm leading-relaxed">{project.impact}</p>
                </div>
              )}
              
              <div class="flex flex-wrap gap-2 mt-auto pt-5 border-t border-white/5 relative z-10">
                {project.techStack.map(tech => (
                  <span class="text-[11px] font-medium text-zinc-400 bg-black/40 px-2.5 py-1 rounded-md border border-white/5 hover:bg-white/10 transition-colors">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
