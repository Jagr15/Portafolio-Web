---
import { profileData } from '../data/profile.data';
---

<section id="proyectos" class="py-24 relative z-10 border-t border-white/[0.02]">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(139,92,246,0.03)_0%,_transparent_70%)] pointer-events-none"></div>
  
  <div class="section-container">
    <div class="mb-16 md:mb-20 fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Casos de Estudio</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-violet-500 to-transparent rounded-full"></div>
      <p class="mt-5 text-zinc-400 text-lg max-w-2xl leading-relaxed">
        Arquitecturas reales resolviendo problemas de negocio complejos.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {profileData.caseStudies.map((study, idx) => (
        <div class={`glass-card ${idx % 2 === 0 ? 'gradient-border-violet' : 'gradient-border-teal'} flex flex-col group transition-all duration-300 hover:bg-[#18181b]/80 hover:-translate-y-2 hover:shadow-[0_12px_40px_rgba(0,0,0,0.5)] fade-up delay-${(idx % 3) * 100}`}>
          <div class="p-6 md:p-8 flex-1 flex flex-col relative overflow-hidden">
             <!-- Glow sutil en hover -->
            <div class={`absolute top-0 right-0 w-32 h-32 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ${idx % 2 === 0 ? 'bg-violet-500/10' : 'bg-teal-500/10'}`}></div>

            <div class="mb-4 relative z-10">
              <span class={`inline-block px-3 py-1 bg-white/5 border border-white/10 text-xs font-semibold text-zinc-300 rounded-full mb-4 group-hover:border-white/20 transition-colors`}>
                {study.context}
              </span>
              <h3 class="text-xl md:text-2xl font-bold text-white tracking-tight transition-colors">{study.title}</h3>
            </div>
            
            <div class="space-y-4 mb-8 flex-1 relative z-10">
              <div>
                <span class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest block mb-1">Problema</span>
                <p class="text-zinc-400 text-sm leading-relaxed">{study.problem}</p>
              </div>
              <div>
                <span class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest block mb-1">Solución</span>
                <p class="text-zinc-300 text-sm leading-relaxed">{study.solution}</p>
              </div>
            </div>
            
            <div class={`p-4 rounded-xl bg-white/[0.02] border border-white/5 mb-6 transition-colors relative z-10 ${idx % 2 === 0 ? 'group-hover:bg-violet-500/5 group-hover:border-violet-500/20' : 'group-hover:bg-teal-500/5 group-hover:border-teal-500/20'}`}>
              <span class={`text-xs font-semibold uppercase tracking-widest block mb-1 flex items-center ${idx % 2 === 0 ? 'text-violet-400' : 'text-teal-400'}`}>
                <svg class="w-3 h-3 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                Impacto Operativo
              </span>
              <p class="text-zinc-300 text-sm leading-relaxed">{study.impact}</p>
            </div>
            
            <div class="flex flex-wrap gap-2 mt-auto pt-5 border-t border-white/5 relative z-10">
              {study.techStack.map(tech => (
                <span class="text-[11px] font-medium text-zinc-400 bg-white/5 px-2.5 py-1 rounded-md border border-white/5">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
