---
import { profileData } from '../data/profile.data';
---

<section id="stack" class="py-20 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 sm:mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Stack y Herramientas</h2>
      <div class="w-16 h-1 bg-primary-500 rounded-full"></div>
      <p class="mt-3 sm:mt-4 text-slate-400">Tecnologías y herramientas con las que trabajo</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {profileData.stack.map(group => {
        const isPrincipal = group.category === "Stack Principal";
        return (
        <div class={`rounded-xl p-6 transition-all group ${isPrincipal ? 'md:col-span-2 xl:col-span-3 bg-gradient-to-br from-slate-800/80 to-slate-900/80 border border-primary-900/50 shadow-lg shadow-primary-900/10' : 'bg-slate-900/80 border border-slate-800/80 hover:border-slate-700'}`}>
          <h3 class={`text-lg font-semibold mb-4 flex items-center ${isPrincipal ? 'text-primary-300' : 'text-white'}`}>
            <span class={`w-2 h-2 rounded-full mr-2 group-hover:shadow-[0_0_8px_rgba(59,130,246,0.8)] transition-all ${isPrincipal ? 'bg-primary-400' : 'bg-slate-600 group-hover:bg-primary-500'}`}></span>
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2.5">
            {group.items.map(item => (
              <span class={`px-3 py-1.5 text-sm rounded-md border transition-colors cursor-default ${isPrincipal ? 'bg-primary-950/40 text-primary-200 border-primary-800/50 hover:bg-primary-900/60 hover:border-primary-500/50' : 'bg-slate-800/50 text-slate-300 border-slate-700/50 hover:bg-slate-800 hover:border-slate-600 hover:text-white'}`}>
                {item}
              </span>
            ))}
          </div>
        </div>
      )})}
    </div>
  </div>
</section>
