---
import { profileData } from '../data/profile.data';
---

<section id="stack" class="py-24 relative z-10 border-t border-white/[0.02]">
  <div class="section-container">
    <div class="mb-16 md:mb-20 fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Ecosistema Tecnológico</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-violet-500 via-teal-500 to-amber-500 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
      {profileData.skills.map((group, idx) => {
        const isCore = group.category.includes("Backend") || group.category.includes("Frontend");
        
        // Asignar colores variados por categoría para dar más personalidad
        let dotColor = "bg-zinc-500";
        let hoverBorder = "hover:border-zinc-500/50";
        
        if (group.category.includes("Backend")) { dotColor = "bg-violet-500"; hoverBorder = "hover:border-violet-500/50"; }
        else if (group.category.includes("Frontend")) { dotColor = "bg-teal-500"; hoverBorder = "hover:border-teal-500/50"; }
        else if (group.category.includes("Datos")) { dotColor = "bg-blue-500"; hoverBorder = "hover:border-blue-500/50"; }
        else if (group.category.includes("Cloud")) { dotColor = "bg-amber-500"; hoverBorder = "hover:border-amber-500/50"; }
        else if (group.category.includes("Testing")) { dotColor = "bg-emerald-500"; hoverBorder = "hover:border-emerald-500/50"; }
        else if (group.category.includes("CMS")) { dotColor = "bg-rose-500"; hoverBorder = "hover:border-rose-500/50"; }

        return (
          <div class={`glass-card gradient-border p-6 md:p-8 flex flex-col group transition-all duration-300 hover:bg-[#18181b]/80 hover:-translate-y-1 hover:shadow-xl fade-up delay-${(idx % 3) * 100} ${isCore ? 'lg:col-span-2' : ''}`}>
            <h3 class="text-lg font-bold text-white mb-6 tracking-tight flex items-center">
              <div class={`w-2 h-2 rounded-full mr-3 ${dotColor} shadow-[0_0_8px_currentColor] opacity-80 group-hover:opacity-100 transition-opacity`}></div>
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2 mt-auto">
              {group.items.map(item => (
                <span class={`px-3 py-1.5 text-sm font-medium rounded-lg bg-black/20 text-zinc-300 border border-white/5 transition-all cursor-default ${hoverBorder} hover:text-white hover:bg-white/5`}>
                  {item}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
