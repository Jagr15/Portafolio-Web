---
import { profileData } from '../data/profile.data';
---

<section id="contacto" class="py-32 relative z-10 border-t border-white/[0.02] bg-gradient-to-b from-transparent to-[#0a0a0a]">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-violet-600/10 rounded-[100%] blur-[120px] pointer-events-none z-[-1]"></div>

  <div class="section-container max-w-3xl text-center fade-up">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-[#18181b] border border-white/10 mb-8 shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-300">
      <svg class="w-8 h-8 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
    </div>
    
    <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-tight">{profileData.cta.title}</h2>
    <p class="text-lg md:text-xl text-zinc-400 mb-12 max-w-2xl mx-auto leading-relaxed text-balance">
      {profileData.cta.subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-4">
      <a href={`mailto:${profileData.cta.email}`} class="w-full sm:w-auto px-8 py-4 rounded-xl bg-gradient-to-r from-violet-600 to-violet-500 text-white font-semibold transition-all hover:from-violet-500 hover:to-violet-400 hover:scale-[1.02] active:scale-95 shadow-[0_0_30px_rgba(139,92,246,0.2)] hover:shadow-[0_0_40px_rgba(139,92,246,0.4)] flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-violet-400 focus:ring-offset-2 focus:ring-offset-[#101011]">
        <svg class="w-5 h-5 mr-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Enviar un Correo
      </a>
      
      <a href="https://wa.me/527299220102?text=Hola%20Jorge%2C%20vi%20tu%20portafolio%20y%20me%20interesan%20tus%20servicios%20o%20tengo%20una%20propuesta%20de%20trabajo." target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-[#18181b] text-zinc-300 font-medium border border-white/10 hover:bg-white/5 transition-all hover:border-emerald-500/50 hover:text-white hover:scale-[1.02] active:scale-95 flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-[#101011]">
        <svg class="w-5 h-5 mr-2.5 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" clip-rule="evenodd" fill-rule="evenodd"></path></svg>
        WhatsApp
      </a>
      
      <a href={profileData.cta.linkedin} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-[#18181b] text-zinc-300 font-medium border border-white/10 hover:bg-white/5 transition-all hover:border-white/20 hover:text-white hover:scale-[1.02] active:scale-95 flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 focus:ring-offset-[#101011]">
        LinkedIn
      </a>
    </div>
  </div>
</section>
