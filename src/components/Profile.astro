---
import { profileData } from '../data/profile.data';
---

<section id="perfil" class="py-24 relative z-10">
  <div class="section-container">
    <div class="mb-16 md:mb-20 fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Perfil Profesional</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-teal-500 to-transparent rounded-full"></div>
    </div>
    
    <div class="grid lg:grid-cols-5 gap-8 items-start fade-up delay-100">
      <div class="lg:col-span-3 glass-card gradient-border p-8 md:p-10 relative overflow-hidden group">
        <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-teal-500/10 rounded-full blur-2xl group-hover:bg-teal-500/20 transition-colors duration-500"></div>
        <p class="text-zinc-300 leading-relaxed text-lg md:text-xl relative z-10">
          {profileData.about.summary}
        </p>
      </div>
      
      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
        {profileData.about.focusAreas.map((area, idx) => (
          <div class={`glass-card p-5 border border-white/5 flex items-center group transition-colors hover:bg-white/[0.04] hover:border-teal-500/20 fade-up delay-${(idx+1)*100}`}>
            <div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mr-4 group-hover:bg-teal-500/10 group-hover:border-teal-500/30 transition-colors shrink-0">
              <svg class="w-5 h-5 text-zinc-400 group-hover:text-teal-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="text-zinc-300 font-medium text-sm md:text-base group-hover:text-white transition-colors">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
